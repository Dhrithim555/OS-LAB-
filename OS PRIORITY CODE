#include <stdio.h>

struct Process {
    int id, at, bt, pr, ct, tat, wt;
};

int main() {
    int n;
    printf("Enter number of processes: ");
    scanf("%d", &n);
    struct Process p[n];
    for (int i = 0; i < n; i++) {
        p[i].id = i + 1;
        printf("P%d AT BT Priority: ", p[i].id);
        scanf("%d %d %d", &p[i].at, &p[i].bt, &p[i].pr);
    }
    int time = 0, completed = 0;
    int visited[n];
    for (int i = 0; i < n; i++) visited[i] = 0;
    while (completed < n) {
        int idx = -1;
        int highest = 9999;

        for (int i = 0; i < n; i++) {
            if (p[i].at <= time && !visited[i]) {
                if (p[i].pr < highest) {
                    highest = p[i].pr;
                    idx = i;
                }
            }
        }
        if (idx != -1) {
            time += p[idx].bt;
            p[idx].ct = time;
            p[idx].tat = p[idx].ct - p[idx].at;
            p[idx].wt = p[idx].tat - p[idx].bt;
            visited[idx] = 1;
            completed++;
        } else {
            time++; // idle CPU
        }
    }
    float avg_tat = 0, avg_wt = 0;
    printf("\nID\tAT\tBT\tPR\tCT\tTAT\tWT\n");
    for (int i = 0; i < n; i++) {
        printf("P%d\t%d\t%d\t%d\t%d\t%d\t%d\n",
               p[i].id, p[i].at, p[i].bt, p[i].pr,
               p[i].ct, p[i].tat, p[i].wt);

        avg_tat += p[i].tat;
        avg_wt += p[i].wt;
    }
    printf("\nAverage Turnaround Time = %.2f", avg_tat / n);
    printf("\nAverage Waiting Time = %.2f\n", avg_wt / n);
    return 0;
}
