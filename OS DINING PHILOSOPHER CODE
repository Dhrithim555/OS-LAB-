#include <stdio.h>
#include <pthread.h>
#include <semaphore.h>
#include <unistd.h>

sem_t f[5];
void *p(void *n) {
    int i = *(int *)n;
    while (1) {
        printf("Philosopher %d is Thinking\n", i);
        sleep(1);
        sem_wait(&f[i]);
        sem_wait(&f[(i + 1) % 5]);
        printf("Philosopher %d is Eating\n", i);
        sleep(1);
        sem_post(&f[i]);
        sem_post(&f[(i + 1) % 5]);
    }
    return NULL;
}

int main() {
    pthread_t t[5];
    int i, a[5];
    printf("Dining Philosopher Problem\n");
    for (i = 0; i < 5; i++)
        sem_init(&f[i], 0, 1);
    for (i = 0; i < 5; i++) {
        a[i] = i;
        pthread_create(&t[i], NULL, p, &a[i]);
    }
    for (i = 0; i < 5; i++)
        pthread_join(t[i], NULL);
    return 0;
}
