#include <stdio.h>

int main() {
    int n, i, j;

    printf("Enter number of processes: ");
    scanf("%d", &n);

    int AT[n], BT[n], CT[n], TAT[n], WT[n], RT[n], ST[n];
    int order[n], temp;

   
    for(i = 0; i < n; i++) {
        printf("Enter Arrival Time and Burst Time for Process %d: ", i+1);
        scanf("%d %d", &AT[i], &BT[i]);
        order[i] = i;   // store process index
    }

   
    for(i = 0; i < n-1; i++) {
        for(j = i+1; j < n; j++) {
            if(AT[order[i]] > AT[order[j]]) {
                temp = order[i];
                order[i] = order[j];
                order[j] = temp;
            }
        }
    }

 
    ST[order[0]] = AT[order[0]];
    CT[order[0]] = ST[order[0]] + BT[order[0]];

   
    for(i = 1; i < n; i++) {
        if(CT[order[i-1]] < AT[order[i]])
            ST[order[i]] = AT[order[i]];
        else
            ST[order[i]] = CT[order[i-1]];

        CT[order[i]] = ST[order[i]] + BT[order[i]];
    }

   
    for(i = 0; i < n; i++) {
        TAT[i] = CT[i] - AT[i];
        WT[i] = TAT[i] - BT[i];
        RT[i] = ST[i] - AT[i];
    }

    printf("\nP\tAT\tBT\tCT\tTAT\tWT\tRT\n");

    for(i = 0; i < n; i++) {
        printf("P%d\t%d\t%d\t%d\t%d\t%d\t%d\n",
        i+1, AT[i], BT[i], CT[i], TAT[i], WT[i], RT[i]);
    }

    return 0;
}
