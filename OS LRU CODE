#include <stdio.h>

int main() {
    int p[20], f[10], t[10], n, m, i, j, pos, min, hit, faults = 0;

    printf("Enter number of pages: ");
    scanf("%d", &n);

    printf("Enter page reference string: ");
    for(i = 0; i < n; i++) scanf("%d", &p[i]);

    printf("Enter number of frames: ");
    scanf("%d", &m);

    for(i = 0; i < m; i++) f[i] = -1;

    for(i = 0; i < n; i++) {
        hit = 0;

        for(j = 0; j < m; j++)
            if(f[j] == p[i]) {
                hit = 1;
                t[j] = i;
            }

        if(!hit) {
            min = 9999;
            for(j = 0; j < m; j++)
                if(f[j] == -1) { pos = j; break; }
                else if(t[j] < min) { min = t[j]; pos = j; }

            f[pos] = p[i];
            t[pos] = i;
            faults++;
        }
    }

    printf("Page Faults = %d", faults);
    return 0;
}
