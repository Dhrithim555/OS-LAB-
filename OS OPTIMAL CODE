#include <stdio.h>

int main() {
    int p[20], f[10], n, m, i, j, k, pos, far, hit, faults = 0;

    printf("Enter number of pages: ");
    scanf("%d", &n);

    printf("Enter page reference string: ");
    for(i = 0; i < n; i++) scanf("%d", &p[i]);

    printf("Enter number of frames: ");
    scanf("%d", &m);

    for(i = 0; i < m; i++) f[i] = -1;

    for(i = 0; i < n; i++) {
        hit = 0;
        for(j = 0; j < m; j++)
            if(f[j] == p[i]) hit = 1;

        if(!hit) {
            for(j = 0; j < m; j++)
                if(f[j] == -1) { pos = j; goto load; }

            far = -1;
            for(j = 0; j < m; j++) {
                for(k = i + 1; k < n && f[j] != p[k]; k++);
                if(k > far) { far = k; pos = j; }
            }

load:
            f[pos] = p[i];
            faults++;
        }
    }

    printf("Page Faults = %d", faults);
    return 0;
}
