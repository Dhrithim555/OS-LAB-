#include <stdio.h>
#include <pthread.h>
#include <semaphore.h>
#include <stdlib.h>

#define N 5

int buf[N], in = 0, out = 0;
sem_t empty, full, mutex;

void* prod(void* p) {
    for (int i = 0; i < 10; i++) {
        int x = rand() % 100;
        sem_wait(&empty);
        sem_wait(&mutex);
        buf[in] = x;
        printf("P : %d at index %d\n", x, in);
        in = (in + 1) % N;
        sem_post(&mutex);
        sem_post(&full);
    }
    return NULL;
}
void* cons(void* p) {
    for (int i = 0; i < 10; i++) {
        sem_wait(&full);
        sem_wait(&mutex);
        int x = buf[out];
        printf("C : %d from index %d\n", x, out);
        out = (out + 1) % N;
        sem_post(&mutex);
        sem_post(&empty);
    }
    return NULL;
}
int main() {
    pthread_t t1, t2;
    sem_init(&empty, 0, N);
    sem_init(&full, 0, 0);
    sem_init(&mutex, 0, 1);
    pthread_create(&t1, NULL, prod, NULL);
    pthread_create(&t2, NULL, cons, NULL);
    pthread_join(t1, NULL);
    pthread_join(t2, NULL);
    sem_destroy(&empty);
    sem_destroy(&full);
    sem_destroy(&mutex);
    return 0;
}
