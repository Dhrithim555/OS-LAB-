#include <stdio.h>

int main() {
    int b[10], p[10], nb, np, i, j;

    printf("Enter number of blocks: ");
    scanf("%d", &nb);
    for(i = 0; i < nb; i++) scanf("%d", &b[i]);

    printf("Enter number of processes: ");
    scanf("%d", &np);
    for(i = 0; i < np; i++) scanf("%d", &p[i]);

    printf("\nProcess\tSize\tBlock\n");

    for(i = 0; i < np; i++) {
        for(j = 0; j < nb; j++) {
            if(b[j] >= p[i]) {
                printf("P%d\t%d\tB%d\n", i + 1, p[i], j + 1);
                b[j] -= p[i];
                break;
            }
        }
        if(j == nb)
            printf("P%d\t%d\tNot Allocated\n", i + 1, p[i]);
    }

    return 0;
}
