#include <stdio.h>

struct Process {
    int pid;
    int burstTime;
    int share;
    int allocated;
};
int main() {
    int n, totalTime = 0;
    printf("Enter no of Processes: ");
    scanf("%d", &n);
    struct Process P[n];
    for (int i = 0; i < n; i++) {
        P[i].pid = i + 1;
        printf("Enter burst time for Process %d: ", P[i].pid);
        scanf("%d", &P[i].burstTime);
        printf("Enter CPU share percentage for Process %d: ", P[i].pid);
        scanf("%d", &P[i].share);
        totalTime += P[i].burstTime;
    }
    printf("\nProportional Scheduling\n");
    for (int i = 0; i < n; i++) {
        P[i].allocated = (P[i].share * totalTime) / 100;
        if (P[i].allocated > P[i].burstTime)
            P[i].allocated = P[i].burstTime;
    }
    printf("\nPID\tBurst Time\tShare\tAllocated CPU Time\n");
    for (int i = 0; i < n; i++) {
        printf("%d\t%d\t\t%d%%\t%d\n",
               P[i].pid,
               P[i].burstTime,
               P[i].share,
               P[i].allocated);
    }
    return 0;
}
