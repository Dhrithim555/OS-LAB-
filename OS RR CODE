#include <stdio.h>

int main() {
    int n, tq;

    printf("Enter number of processes: ");
    scanf("%d", &n);

    int at[n], bt[n], rt[n];
    int ct[n], wt[n], tat[n], response[n];
    int visited[n]; // to track first response

    // Input
    printf("Enter Arrival Times:\n");
    for(int i = 0; i < n; i++) {
        printf("P%d: ", i+1);
        scanf("%d", &at[i]);
    }

    printf("Enter Burst Times:\n");
    for(int i = 0; i < n; i++) {
        printf("P%d: ", i+1);
        scanf("%d", &bt[i]);
        rt[i] = bt[i];   // remaining time
        visited[i] = 0;  // not started yet
    }

    printf("Enter Time Quantum: ");
    scanf("%d", &tq);

    int time = 0, completed = 0;

    while(completed < n) {
        int found = 0;

        for(int i = 0; i < n; i++) {
            if(at[i] <= time && rt[i] > 0) {
                found = 1;

                // First response time
                if(visited[i] == 0) {
                    response[i] = time - at[i];
                    visited[i] = 1;
                }

                if(rt[i] > tq) {
                    time += tq;
                    rt[i] -= tq;
                } else {
                    time += rt[i];
                    ct[i] = time;  // completion time
                    rt[i] = 0;
                    completed++;
                }
            }
        }

        // If no process is ready, move time forward
        if(!found) {
            time++;
        }
    }

    // Calculate WT and TAT
    for(int i = 0; i < n; i++) {
        tat[i] = ct[i] - at[i];
        wt[i] = tat[i] - bt[i];
    }

    // Output
    float total_wt = 0, total_tat = 0, total_rt = 0;

    printf("\nProcess\tAT\tBT\tCT\tTAT\tWT\tRT\n");
    for(int i = 0; i < n; i++) {
        printf("P%d\t%d\t%d\t%d\t%d\t%d\t%d\n",
               i+1, at[i], bt[i], ct[i], tat[i], wt[i], response[i]);

        total_wt += wt[i];
        total_tat += tat[i];
        total_rt += response[i];
    }

    printf("\nAverage Waiting Time = %.2f", total_wt / n);
    printf("\nAverage Turnaround Time = %.2f", total_tat / n);
    printf("\nAverage Response Time = %.2f\n", total_rt / n);

    return 0;
}
